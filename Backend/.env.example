# copy this to .env (or just export the vars) before running the backend.
# .env is gitignored, never commit real keys.

# --- required for the real agent (langgraph engine) ---
# without this the langgraph engine can't call the model. the default
# "testing" engine does not need it.
OPENAI_API_KEY=

# --- which engine the backend runs ---
# testing  = fake but realistic streamed run, no api key, no model calls
# langgraph = the real parallel orchestrator (needs OPENAI_API_KEY + deps)
WAPO_AGENT_ENGINE=testing

# --- where the websocket server listens (loopback only) ---
WAPO_BACKEND_HOST=127.0.0.1
WAPO_BACKEND_PORT=8765

# --- optional: only matters if you let the swift app launch the backend ---
# point this at the python you want it to use
# WAPO_PYTHON_PATH=/opt/homebrew/bin/python3
# where to find server.py if it's not bundled in the app
# WAPO_PROJECT_ROOT=/path/to/Wapo
# WAPO_BACKEND_SERVER_PATH=/path/to/Wapo/Backend/server.py
# extra hosts to probe besides WAPO_BACKEND_HOST, comma separated
# WAPO_BACKEND_FALLBACK_HOSTS=localhost

# --- optional: background gateway voice escalation (Config/, scaffolding) ---
# only needed if you wire up the openclaw gateway + twilio escalation
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# USER_PHONE_NUMBER=
